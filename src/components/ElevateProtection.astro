---
// White bg, "Premium Phone Repair" (orange-red), "Elevate Your Phone's Protection and Style", text, Book Repair + Shop Accessories, right: phone + accessories
---

<section id="about" class="bg-white py-16 md:py-24">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-12 px-4 md:flex-row md:items-center md:justify-between md:gap-16 lg:px-8">
    <div class="flex-1 md:order-2">
      <p class="text-sm font-normal text-accent-coral">Premium Phone Repair</p>
      <h2 class="mt-2 text-4xl font-bold leading-tight tracking-tight text-copy-dark sm:text-5xl">
        Elevate Your Phone's Protection and Style
      </h2>
      <p class="mt-4 max-w-md text-lg text-copy-medium leading-relaxed">
        Discover the Perfect Balance of Protection and Personalization for Your Device. Our Armor Film and Accessory Solutions Offer Unparalleled Defense Against Damage.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="#contact" class="inline-flex items-center justify-center rounded-lg bg-accent-coral px-8 py-3.5 text-base font-medium text-white hover:opacity-90 transition-opacity">
          Book Repair
        </a>
        <a href="#products" class="inline-flex items-center justify-center rounded-lg border border-border-mid bg-white px-8 py-3.5 text-base font-medium text-copy-dark hover:bg-slate-50 transition-colors">
          Shop Accessories
        </a>
      </div>
    </div>
    <div class="flex-1 relative flex flex-wrap items-center justify-center gap-4 md:order-1 md:min-h-[280px]">
      <div class="relative h-56 w-32 rounded-[1.5rem] border-[6px] border-copy-dark bg-copy-dark shadow-lg" style="transform: rotate(-6deg);">
        <div class="absolute inset-1.5 rounded-[1.2rem] bg-slate-700" />
      </div>
      <div class="h-20 w-20 rounded-xl bg-slate-200 shadow" />
      <div class="h-16 w-24 rounded-lg bg-slate-300 shadow" />
      <div class="h-14 w-14 rounded-lg bg-slate-400 shadow" />
    </div>
  </div>
</section>
