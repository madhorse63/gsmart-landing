---
interface Props {
  title?: string;
  subtitle?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  title = 'Готовы обсудить проект?',
  subtitle = 'Оставьте заявку — мы свяжемся в течение дня и предложим план действий.',
  buttonText = 'Связаться',
  buttonHref = '#contact',
} = Astro.props;
---

<section id="contact" class="py-20 md:py-28 bg-indigo-600">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {title}
      </h2>
      <p class="mt-4 text-lg text-indigo-100">
        {subtitle}
      </p>
      <div class="mt-10">
        <a
          href={buttonHref}
          class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-3 text-base font-semibold text-indigo-600 shadow-sm hover:bg-indigo-50 transition-colors"
        >
          {buttonText}
        </a>
      </div>
    </div>
  </div>
</section>
