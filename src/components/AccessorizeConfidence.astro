---
// White bg, "Accessorize with Confidence" (centered heading), 4 product images in grid - light grey card bg
---

<section class="bg-white py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center text-3xl font-semibold text-copy-dark sm:text-4xl">Accessorize with Confidence</h2>
    <div class="mt-16 grid grid-cols-2 gap-6 lg:grid-cols-4 lg:gap-8">
      <div class="rounded-xl bg-[#F7F7F7] p-6">
        <div class="aspect-[3/4] w-full rounded-lg bg-gradient-to-br from-pink-300 via-purple-300 to-blue-300" />
      </div>
      <div class="rounded-xl bg-[#F7F7F7] p-6">
        <div class="aspect-[3/4] w-full rounded-lg bg-gradient-to-br from-rose-200 to-amber-100" />
      </div>
      <div class="rounded-xl bg-[#F7F7F7] p-6">
        <div class="aspect-[3/4] w-full rounded-lg bg-gradient-to-br from-orange-200 to-slate-300" />
      </div>
      <div class="rounded-xl bg-[#F7F7F7] p-6">
        <div class="aspect-[3/4] w-full rounded-lg bg-gradient-to-br from-slate-700 to-slate-900" />
      </div>
    </div>
  </div>
</section>
