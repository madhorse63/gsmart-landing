---
const features = [
  {
    title: 'Tempered Glass Screen',
    description: "Shield your phone's display from scratches, cracks, and shatters with our premium tempered glass screen protectors.",
    icon: 'lock',
  },
  {
    title: 'Stylish Phone Cases',
    description: "Elevate your phone's style and protection with our curated selection of sleek and durable cases.",
    icon: 'briefcase',
  },
  {
    title: 'Charging Cables and Adapters',
    description: 'Keep your phone powered up and connected with our reliable charging cables and adapters.',
    icon: 'zap',
  },
];
---

<section id="about" class="bg-slate-50/50 py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium text-slate-500">Protect Your Investment</p>
    <h2 class="mt-2 text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Accessory Solutions</h2>
    <div class="mt-16 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-700" aria-hidden="true">
            {f.icon === 'lock' && (
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            )}
            {f.icon === 'briefcase' && (
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            )}
            {f.icon === 'zap' && (
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            )}
          </div>
          <h3 class="mt-5 text-lg font-bold text-slate-900">{f.title}</h3>
          <p class="mt-2 text-slate-600">{f.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
