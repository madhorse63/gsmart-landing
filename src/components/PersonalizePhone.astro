---
// Light purple/pale pink bg, left: 2-3 phones (mint, gold, black), right: "Personalize Your Phone's", description, Shop Now (white outline)
---

<section class="bg-brand-lilac py-16 md:py-24">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-12 px-4 md:flex-row md:items-center md:justify-between md:gap-12 lg:px-8">
    <div class="flex-1 flex justify-center md:order-1">
      <div class="relative h-72 w-56 sm:w-64">
        <div class="absolute left-0 top-2 h-52 w-26 rounded-[1.6rem] border-[8px] border-emerald-200 bg-emerald-100 shadow-lg" style="transform: rotate(-6deg);">
          <div class="absolute inset-1.5 rounded-[1.1rem] bg-slate-700" />
        </div>
        <div class="absolute left-14 top-6 h-56 w-28 rounded-[1.75rem] border-[8px] border-copy-dark bg-copy-dark shadow-lg" style="transform: rotate(-2deg);">
          <div class="absolute inset-1.5 rounded-[1.2rem] bg-slate-800" />
        </div>
      </div>
    </div>
    <div class="flex-1 md:order-2">
      <h2 class="text-3xl font-bold leading-tight text-copy-dark sm:text-4xl">
        Personalize Your<br />Phone's
      </h2>
      <p class="mt-4 max-w-lg text-base text-copy-medium leading-relaxed">
        Discover the Ultimate in Phone Personalization and Protection with Our Armor Film and Accessory Solutions.
      </p>
      <a href="#products" class="mt-8 inline-block rounded-lg border border-border-mid bg-white px-8 py-3.5 text-base font-medium text-copy-dark shadow-sm hover:bg-slate-50 transition-colors">
        Shop Now
      </a>
    </div>
  </div>
</section>
