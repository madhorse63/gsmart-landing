---
const cards = [
  {
    title: 'iPhone 11 Repair',
    description: 'Bring your iPhone 11 back to life with our expert repair services.',
    bg: 'bg-pink-50',
    phoneBg: 'from-slate-100 to-slate-200',
  },
  {
    title: 'iPhone 11 Pro',
    description: 'Keeping your iPhone 11 Pro in top shape is our priority.',
    bg: 'bg-sky-50',
    phoneBg: 'from-slate-800 to-slate-900',
  },
  {
    title: 'iPhone 11 Max Repair',
    description: 'Revive your iPhone 11 Max with our comprehensive repair solutions.',
    bg: 'bg-slate-100',
    phoneBg: 'from-slate-800 to-slate-900',
  },
];
---

<section id="repair" class="bg-white py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium uppercase tracking-wider text-slate-500">Trusted by Locals</p>
    <h2 class="mt-2 text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Our Repair Services</h2>
    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {cards.map((card) => (
        <article class={`rounded-2xl ${card.bg} p-8 shadow-sm transition-shadow hover:shadow-md`}>
          <div class={`mx-auto h-40 w-32 rounded-[1.5rem] bg-gradient-to-b ${card.phoneBg} shadow-lg`}>
            <div class="mx-auto mt-3 h-4 w-16 rounded-full bg-black/30" />
          </div>
          <h3 class="mt-6 text-lg font-bold text-slate-900">{card.title}</h3>
          <p class="mt-2 text-slate-600">{card.description}</p>
        </article>
      ))}
    </div>
    <p class="mt-20 text-center text-sm font-medium text-slate-500">Protect Your Investment</p>
  </div>
</section>
