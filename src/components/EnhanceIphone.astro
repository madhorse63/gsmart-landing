---
// Light purplish-pink bg, left: "Enhance Your Phone's", text, Shop Armor Film (pink) + Explore Accessories (outline), right: rose gold iPhone + 3D icons
---

<section class="bg-brand-lilac py-16 md:py-24">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-12 px-4 md:flex-row md:items-center md:justify-between md:gap-12 lg:px-8">
    <div class="flex-1">
      <h2 class="text-3xl font-bold leading-tight text-copy-dark sm:text-4xl">
        Enhance Your<br />Phone's
      </h2>
      <p class="mt-4 max-w-lg text-base text-copy-medium leading-relaxed">
        Unlock the Full Potential of Your Device with Our Premium Armor Film and Accessory Solutions. Protect Your Investment, Elevate Your Style.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="#products" class="inline-flex items-center justify-center rounded-lg bg-[#FF4D6D] px-8 py-3.5 text-base font-medium text-white hover:opacity-90 transition-opacity">
          Shop Armor Film
        </a>
        <a href="#products" class="inline-flex items-center justify-center rounded-lg border border-border-mid bg-white px-8 py-3.5 text-base font-medium text-copy-dark hover:bg-slate-50 transition-colors">
          Explore Accessories
        </a>
      </div>
    </div>
    <div class="flex-1 relative flex justify-center">
      <div class="relative h-80 w-64">
        <div class="absolute inset-0 rounded-[2.25rem] border-[10px] border-amber-200 bg-amber-50 shadow-xl" style="transform: rotate(5deg);">
          <div class="absolute inset-2 rounded-[1.75rem] bg-slate-800" />
          <div class="absolute top-4 left-1/2 h-5 w-20 -translate-x-1/2 rounded-full bg-black/50" />
        </div>
        <div class="absolute -right-4 bottom-8 h-12 w-12 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 shadow-lg" />
        <div class="absolute right-0 top-1/2 h-10 w-10 rounded-full border-2 border-slate-300 bg-gradient-to-br from-pink-400 to-purple-500 shadow" />
      </div>
    </div>
  </div>
</section>
