---
const currentYear = new Date().getFullYear();
// Footer: WHITE background, mountain peaks icon, copyright, Quick Links, Explore More, Connect With Us
---

<footer id="contact" class="bg-white border-t border-border-light">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-12 md:flex-row md:justify-between md:gap-8">
      <div>
        <a href="#" class="inline-flex items-center gap-2 text-copy-dark" aria-label="Armored">
          <span class="flex h-10 w-10 items-center justify-center text-copy-dark">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-8 w-8"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span class="text-lg font-semibold">Armored</span>
        </a>
        <p class="mt-4 text-sm text-copy-medium">© {currentYear} Armored, Inc.</p>
        <p class="text-sm text-copy-medium">All rights reserved.</p>
      </div>
      <div class="flex flex-wrap gap-12 md:gap-16">
        <div>
          <h3 class="text-sm font-semibold text-copy-dark">Quick Links</h3>
          <ul class="mt-4 space-y-2 text-sm text-copy-medium">
            <li><a href="#hero" class="hover:text-copy-dark transition-colors">Home</a></li>
            <li><a href="#about" class="hover:text-copy-dark transition-colors">About</a></li>
            <li><a href="#products" class="hover:text-copy-dark transition-colors">Products</a></li>
            <li><a href="#contact" class="hover:text-copy-dark transition-colors">Contact</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-copy-dark">Explore More</h3>
          <ul class="mt-4 space-y-2 text-sm text-copy-medium">
            <li><a href="#faq" class="hover:text-copy-dark transition-colors">FAQ</a></li>
            <li><a href="#" class="hover:text-copy-dark transition-colors">Careers</a></li>
            <li><a href="#" class="hover:text-copy-dark transition-colors">Warranty</a></li>
            <li><a href="#" class="hover:text-copy-dark transition-colors">Shipping</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-copy-dark">Connect With Us</h3>
          <ul class="mt-4 space-y-2 text-sm text-copy-medium">
            <li><a href="#" class="hover:text-copy-dark transition-colors">Facebook</a></li>
            <li><a href="#" class="hover:text-copy-dark transition-colors">Twitter</a></li>
            <li><a href="#" class="hover:text-copy-dark transition-colors">Instagram</a></li>
            <li><a href="#" class="hover:text-copy-dark transition-colors">LinkedIn</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>
